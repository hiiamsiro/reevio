{
  "name": "reevio",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "corepack pnpm --parallel -r run dev",
    "dev:web": "corepack pnpm -F web dev",
    "dev:api": "corepack pnpm -F api dev",
    "dev:worker": "corepack pnpm -F worker dev",
    "build": "corepack pnpm -F api prisma:generate && corepack pnpm -r run build",
    "build:web": "corepack pnpm -F web build",
    "build:api": "corepack pnpm -F api build",
    "build:worker": "corepack pnpm -F worker build",
    "lint": "corepack pnpm -r run lint",
    "typecheck": "corepack pnpm -r run typecheck",
    "test": "corepack pnpm -r run test",
    "test:e2e": "corepack pnpm -r run test:e2e",
    "db:migrate": "corepack pnpm -F api prisma migrate dev",
    "db:generate": "corepack pnpm -F api prisma generate",
    "db:studio": "corepack pnpm -F api prisma studio",
    "db:seed": "corepack pnpm -F api prisma db seed",
    "db:push": "corepack pnpm -F api prisma db push",
    "clean": "corepack pnpm -r run clean && rm -rf node_modules",
    "format": "corepack pnpm -r run format",
    "genz": "turbo gen"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@types/node": "^22.13.10",
    "eslint": "^9.39.1",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0"
    }
  }
}
