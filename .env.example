# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reevio"

# Redis
REDIS_URL="redis://localhost:6379"

# Storage
STORAGE_DRIVER="local"
STORAGE_PATH="./storage"
STORAGE_PUBLIC_BASE_URL="http://localhost:4000"

# Auth
AUTH_SECRET="change-me-in-development"
AUTH_URL="http://localhost:3000"

# Default provider
VIDEO_PROVIDER="remotion"

# API URLs
NEXT_PUBLIC_API_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# Video Providers
REMOTION_LICENSE_KEY=""
TOPVIEW_API_KEY=""
GROK_API_KEY=""
GOOGLE_FLOW_API_KEY=""
VEO_API_KEY=""

# Webhooks
WEBHOOK_SECRET=""

# Runtime
PORT=4000
NODE_ENV=development
