# Database
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/reevio"

# Redis
REDIS_URL="redis://redis:6379"

# Storage
STORAGE_DRIVER="local"
STORAGE_PATH="/app/storage"
STORAGE_PUBLIC_BASE_URL="https://api.reevio.app"

# Auth
AUTH_SECRET="replace-in-production"
AUTH_URL="https://app.reevio.app"

# Default provider
VIDEO_PROVIDER="remotion"

# API URLs
NEXT_PUBLIC_API_URL="https://app.reevio.app"
API_URL="https://api.reevio.app"

# Runtime
PORT=4000
NODE_ENV=production

# Video Providers
REMOTION_LICENSE_KEY=""
TOPVIEW_API_KEY=""
GROK_API_KEY=""
GOOGLE_FLOW_API_KEY=""
VEO_API_KEY=""

# Webhooks
WEBHOOK_SECRET=""
