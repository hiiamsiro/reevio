{
  "name": "worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "bullmq": "^5.28.0",
    "ioredis": "^5.6.0",
    "zod": "^3.24.2",
    "@reevio/types": "workspace:*",
    "@reevio/config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.19.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.0"
  }
}
