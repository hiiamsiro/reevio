{
  "name": "worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "db:generate": "pnpm exec prisma generate --schema prisma/schema.prisma",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "@prisma/client": "^6.3.0",
    "@reevio/config": "workspace:*",
    "@reevio/types": "workspace:*",
    "@remotion/bundler": "^4.0.448",
    "@remotion/media": "^4.0.448",
    "@remotion/renderer": "^4.0.448",
    "bullmq": "^5.28.0",
    "ioredis": "^5.6.0",
    "node-edge-tts": "^1.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "remotion": "^4.0.448",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.19.0",
    "prisma": "^6.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.0"
  }
}
