# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reevio"

# Redis
REDIS_URL="redis://localhost:6379"

# Storage
STORAGE_DRIVER="local"
STORAGE_PATH="./storage"
STORAGE_PUBLIC_BASE_URL="http://localhost:4000"

# Image Providers
IMAGE_PROVIDER_ORDER="cloudflare,huggingface,pexels,pixabay"
CF_ACCOUNT_ID=""
CF_API_TOKEN=""
CF_IMAGE_MODEL="@cf/black-forest-labs/flux-1-schnell"
HF_API_KEY=""
HF_IMAGE_MODEL="black-forest-labs/FLUX.1-schnell"
PEXELS_API_KEY=""
PIXABAY_API_KEY=""
IMAGE_PROVIDER_TIMEOUT_MS="25000"
IMAGE_PROVIDER_COOLDOWN_SECONDS="300"

# Edge TTS
EDGE_TTS_VOICE="vi-VN-HoaiMyNeural"
EDGE_TTS_LANG="vi-VN"
EDGE_TTS_OUTPUT_FORMAT="audio-24khz-48kbitrate-mono-mp3"
EDGE_TTS_RATE="default"
EDGE_TTS_PITCH="default"
EDGE_TTS_VOLUME="default"
EDGE_TTS_PROXY=""
EDGE_TTS_TIMEOUT_MS="15000"

# Auth
AUTH_SECRET="change-me-in-development"

# API URLs
NEXT_PUBLIC_API_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# Runtime
PORT=4000
NODE_ENV=development
